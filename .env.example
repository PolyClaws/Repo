# ─── Solana ───────────────────────────────────────────────
# RPC endpoint (e.g. Helius, QuickNode, or mainnet-beta)
SOLANA_RPC=

# Agent wallet private key (base58)
AGENT_WALLET_PRIVATE_KEY=

# $POLYCLAW token mint address
POLYCLAW_MINT=

# ─── Polygon ──────────────────────────────────────────────
# Polygon RPC endpoint
POLYGON_RPC=https://polygon-rpc.com

# Agent wallet private key for Polygon (hex, 0x-prefixed)
POLYGON_WALLET_KEY=

# ─── Inference ────────────────────────────────────────────
# Anthropic API key (agent decision layer)
AGENT_INFERENCE_KEY=

# Model to use for agent decisions
AGENT_MODEL=claude-sonnet-4-6

# ─── Internal Bridge ──────────────────────────────────────
# URL where the Next.js frontend is hosted
# Used by agent-runner to POST activity logs
INGEST_URL=http://localhost:3000/api/ingest

# Shared secret for authenticating agent → frontend posts
INGEST_SECRET=

# ─── Optional ─────────────────────────────────────────────
# PumpSwap pool address (only required for TIDECLAW LP management)
# Leave blank — bonding curve / PumpSwap handled automatically
# PUMPSWAP_POOL=
